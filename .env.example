# --- Database (Postgres) ---
# Local dev: Docker compose Postgres
# Production: Neon pooled URL (with ?sslmode=require&pgbouncer=true) for app reads/writes,
#             and the direct URL for migrations.
DATABASE_URL="postgresql://devrace:devrace@localhost:5432/devrace?schema=public"
DIRECT_URL="postgresql://devrace:devrace@localhost:5432/devrace?schema=public"

# --- Better Auth ---
# Generate a fresh secret per environment: `openssl rand -hex 32`
BETTER_AUTH_SECRET="change-me-to-a-32-char-random-string"
# Local: http://localhost:3000. Production: your public origin, e.g. https://bugrush.lol
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create an OAuth 2.0 Web Application client at https://console.cloud.google.com
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://bugrush.lol/api/auth/callback/google
#   https://www.bugrush.lol/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Realtime (Upstash Redis) ---
# Optional locally (falls back to in-process bus). Required on Vercel for chat / PvP sync.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Vercel Blob (avatar uploads) ---
# Set automatically by Vercel when you connect a Blob store. Optional locally.
BLOB_READ_WRITE_TOKEN=""
