{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bugrush",
  "version": "0.1.0",
  "identifier": "lol.bugrush.desktop",
  "build": {
    "frontendDist": "https://bugrush.lol",
    "devUrl": "https://bugrush.lol"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bugrush",
        "url": "https://bugrush.lol",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "transparent": false,
        "backgroundColor": "#09090b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Bugrush desktop client",
    "longDescription": "Bugrush — competitive debugging game, packaged as a desktop client."
  }
}
