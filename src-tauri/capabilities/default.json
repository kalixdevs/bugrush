{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window. Grants the wrapped remote URL the minimal window-control permissions needed by the custom title bar.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://bugrush.lol/*",
      "https://www.bugrush.lol/*",
      "http://localhost:3000/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:event:default"
  ]
}
